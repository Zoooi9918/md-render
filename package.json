{
  "name": "md-render",
  "version": "0.1.0",
  "description": "A performance-first markdown-to-HTML renderer with Obsidian-flavored extensions, distributed via CDN.",
  "main": "dist/md-render.umd.js",
  "module": "dist/md-render.esm.js",
  "browser": "dist/md-render.iife.js",
  "unpkg": "dist/md-render.umd.min.js",
  "jsdelivr": "dist/md-render.umd.min.js",
  "type": "module",
  "license": "MIT",
  "repository": "https://github.com/Zoooi9918/md-render",
  "keywords": [
    "markdown",
    "renderer",
    "html",
    "obsidian",
    "cdn",
    "markdown-it"
  ],
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/md-render.esm.js",
      "require": "./dist/md-render.umd.js",
      "default": "./dist/md-render.iife.js"
    },
    "./css": "./dist/md-render.css",
    "./css/min": "./dist/md-render.min.css"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:css": "node scripts/build-css.mjs",
    "clean": "rimraf dist src/styles/inline.generated.js",
    "test": "node tests/smoke.mjs",
    "prepublishOnly": "npm run clean && npm run build && npm test",
    "dev": "echo Use Live Server on examples/dev-preview.html"
  },
  "dependencies": {
    "markdown-it": "^14.2.0",
    "markdown-it-deflist": "^3.0.1",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^3.0.3",
    "markdown-it-ins": "^4.0.0",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1"
  },
  "devDependencies": {
    "csso": "^5.0.5",
    "esbuild": "^0.24.2",
    "rimraf": "^5.0.10"
  },
  "homepage": "https://Zoooi9918.github.io/md-render/",
  "bugs": "https://github.com/Zoooi9918/md-render/issues"
}
